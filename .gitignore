.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub/
build/

# IDE
.idea/
.vscode/
.claude/
*.iml
*.ipr
*.iws

# OS
.DS_Store
Thumbs.db

# Flutter build artifacts
*.g.dart
*.freezed.dart
*.mocks.dart

# Secrets & Environment
.env
.env.*
!.env.example
!.env.template
*.key
*.pem
secrets/
android/key.properties
ios/Runner/GoogleService-Info.plist

# Isar local database
*.isar
*.isar.lock
*.isar.json
libisar.dylib
libisar.so

# Android
android/.gradle/
android/app/build/
